<Window x:Class="PixelAnimator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pixel Animator — Sprite Sheet Preview"
        MinWidth="780" MinHeight="560"
        Width="1080" Height="800"
        Background="#0F0F13"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Foreground="White"
        FontFamily="Consolas">

    <Window.Resources>
        <!-- Button style -->
        <Style x:Key="PixelBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#313244"/>
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#585B70"/>
                                <Setter Property="BorderBrush" Value="#313244"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="PixelBtnAccent" TargetType="Button" BasedOn="{StaticResource PixelBtn}">
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4A70"/>
                    <Setter Property="BorderBrush" Value="#B4D0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger button -->
        <Style x:Key="PixelBtnDanger" TargetType="Button" BasedOn="{StaticResource PixelBtn}">
            <Setter Property="Background" Value="#3A1E1E"/>
            <Setter Property="BorderBrush" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#F38BA8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A2A2A"/>
                    <Setter Property="BorderBrush" Value="#FFB4C8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="PixelBtnSmall" TargetType="Button" BasedOn="{StaticResource PixelBtn}">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="PixelInput" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#89B4FA"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label style -->
        <Style x:Key="PixelLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Slider style -->
        <Style x:Key="PixelSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="#89B4FA"/>
        </Style>

        <!-- Layer row item -->
        <Style x:Key="LayerRow" TargetType="Border">
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="BorderBrush" Value="#2E2E42"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
        </Style>

        <!-- Selected layer row -->
        <Style x:Key="LayerRowSelected" TargetType="Border" BasedOn="{StaticResource LayerRow}">
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Preview -->
            <ColumnDefinition Width="*"/>
            <!-- Right panel -->
            <ColumnDefinition Width="230"/>
        </Grid.ColumnDefinitions>

        <!-- === LEFT: Preview area === -->
        <Grid Grid.Column="0" Background="#0A0A0F" Margin="0">
            <Canvas x:Name="CheckerCanvas" ClipToBounds="True"/>

            <!-- Composite layer canvas — sprites stack here -->
            <Canvas x:Name="LayerCanvas"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ClipToBounds="False"/>

            <!-- Drop hint -->
            <StackPanel x:Name="DropHint" VerticalAlignment="Center" HorizontalAlignment="Center"
                        IsHitTestVisible="False">
                <TextBlock Text="[ PIXEL ANIMATOR ]" Foreground="#313244"
                           FontSize="18" FontFamily="Consolas" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="add a layer to begin" Foreground="#313244"
                           FontSize="11" FontFamily="Consolas" Margin="0,8,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="or drag &amp; drop a file" Foreground="#313244"
                           FontSize="10" FontFamily="Consolas" Margin="0,4,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Status bar bottom -->
            <Border VerticalAlignment="Bottom" Background="#0F0F1A" BorderBrush="#1E1E2E"
                    BorderThickness="0,1,0,0" Padding="10,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusLabel" Grid.Column="0"
                               Text="No layers loaded" Foreground="#585B70"
                               FontFamily="Consolas" FontSize="10"/>
                    <TextBlock x:Name="FrameCounterLabel" Grid.Column="1"
                               Text="—" Foreground="#89B4FA"
                               FontFamily="Consolas" FontSize="10"/>
                </Grid>
            </Border>
        </Grid>

        <!-- === RIGHT: Control panel === -->
        <Border Grid.Column="1" Background="#13131C" BorderBrush="#1E1E2E" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Layers section — takes most space -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <!-- Playback + settings — fixed bottom -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── LAYERS HEADER + LIST ── -->
                <StackPanel Grid.Row="0" Margin="14,14,14,0">
                    <TextBlock Text="PIXEL ANIMATOR" Foreground="#CDD6F4"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="multi-layer previewer" Foreground="#585B70"
                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,12"/>

                    <!-- Add + Clear buttons -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="AddLayerBtn" Content="[ + ADD LAYER ]"
                                Style="{StaticResource PixelBtnAccent}"
                                Height="28" Click="AddLayerBtn_Click"/>
                        <Button Grid.Column="2" x:Name="ClearAllBtn" Content="✕ CLEAR"
                                Style="{StaticResource PixelBtnDanger}"
                                Height="28" Width="64" Click="ClearAllBtn_Click"/>
                    </Grid>

                    <TextBlock Text="LAYERS" Style="{StaticResource SectionHeader}" Margin="0,6,0,4"/>
                </StackPanel>

                <!-- Layer list -->
                <Border Grid.Row="1" BorderBrush="#1E1E2E" BorderThickness="0,1,0,1" Margin="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="LayerListPanel" Margin="0"/>
                    </ScrollViewer>
                </Border>

                <!-- ── SETTINGS SCROLL ── -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="14,10,14,14">
                    <StackPanel>

                        <!-- Move layer up/down -->
                        <TextBlock Text="SELECTED LAYER" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="MoveUpBtn" Content="▲ UP"
                                    Style="{StaticResource PixelBtnSmall}"
                                    Height="26" Click="MoveUpBtn_Click"/>
                            <Button Grid.Column="2" x:Name="MoveDownBtn" Content="▼ DN"
                                    Style="{StaticResource PixelBtnSmall}"
                                    Height="26" Click="MoveDownBtn_Click"/>
                            <Button Grid.Column="4" x:Name="RemoveLayerBtn" Content="✕ RM"
                                    Style="{StaticResource PixelBtnSmall}"
                                    Height="26" Click="RemoveLayerBtn_Click"
                                    Foreground="#F38BA8"/>
                        </Grid>

                        <Separator Background="#1E1E2E" Margin="0,0,0,10"/>

                        <!-- Frame settings -->
                        <TextBlock Text="FRAME SIZE" Style="{StaticResource SectionHeader}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="W  " Style="{StaticResource PixelLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="WidthInput"
                                     Style="{StaticResource PixelInput}"
                                     Text="64" TextChanged="SizeInput_Changed"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="H  " Style="{StaticResource PixelLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="HeightInput"
                                     Style="{StaticResource PixelInput}"
                                     Text="64" TextChanged="SizeInput_Changed"/>
                        </Grid>

                        <!-- Row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ROW " Style="{StaticResource PixelLabel}"/>
                            <TextBox Grid.Column="1" x:Name="ColumnInput"
                                     Style="{StaticResource PixelInput}"
                                     Text="0" TextChanged="ColumnInput_Changed"/>
                        </Grid>
                        <TextBlock Text="(row index from 0)" Foreground="#45475A"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,10"/>

                        <Separator Background="#1E1E2E" Margin="0,0,0,10"/>

                        <!-- Playback speed -->
                        <TextBlock Text="PLAYBACK" Style="{StaticResource SectionHeader}"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FPS " Style="{StaticResource PixelLabel}"/>
                            <TextBox Grid.Column="1" x:Name="FpsInput"
                                     Style="{StaticResource PixelInput}"
                                     Text="12" TextChanged="FpsInput_Changed"/>
                        </Grid>

                        <Slider x:Name="FpsSlider" Minimum="1" Maximum="60" Value="12"
                                Style="{StaticResource PixelSlider}"
                                Margin="0,4,0,10"
                                ValueChanged="FpsSlider_ValueChanged"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>

                        <Separator Background="#1E1E2E" Margin="0,0,0,10"/>

                        <!-- Playback controls -->
                        <TextBlock Text="CONTROLS" Style="{StaticResource SectionHeader}"/>

                        <UniformGrid Rows="2" Columns="2" Margin="0,0,0,8">
                            <Button x:Name="PrevFrameBtn" Content="◀◀ PREV"
                                    Style="{StaticResource PixelBtn}"
                                    Margin="0,0,3,3" Height="28"
                                    Click="PrevFrameBtn_Click"/>
                            <Button x:Name="NextFrameBtn" Content="NEXT ▶▶"
                                    Style="{StaticResource PixelBtn}"
                                    Margin="3,0,0,3" Height="28"
                                    Click="NextFrameBtn_Click"/>
                            <Button x:Name="PlayBtn" Content="▶  PLAY"
                                    Style="{StaticResource PixelBtnAccent}"
                                    Margin="0,3,3,0" Height="28"
                                    Click="PlayBtn_Click"/>
                            <Button x:Name="PauseBtn" Content="⏸ PAUSE"
                                    Style="{StaticResource PixelBtn}"
                                    Margin="3,3,0,0" Height="28"
                                    Click="PauseBtn_Click"/>
                        </UniformGrid>

                        <CheckBox x:Name="LoopCheck" Content=" LOOP ANIMATION"
                                  IsChecked="True"
                                  Foreground="#A6ADC8" FontFamily="Consolas" FontSize="11"
                                  Margin="0,4,0,0"/>

                        <Separator Background="#1E1E2E" Margin="0,10,0,10"/>

                        <!-- Display scale -->
                        <TextBlock Text="DISPLAY SCALE" Style="{StaticResource SectionHeader}"/>
                        <Slider x:Name="ScaleSlider" Minimum="1" Maximum="8" Value="4"
                                Style="{StaticResource PixelSlider}"
                                Margin="0,0,0,2"
                                ValueChanged="ScaleSlider_ValueChanged"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="ScaleLabel" Text="4x" Foreground="#585B70"
                                   FontFamily="Consolas" FontSize="10" Margin="0,0,0,10"/>

                        <Separator Background="#1E1E2E" Margin="0,0,0,10"/>

                        <!-- Live reload -->
                        <TextBlock Text="LIVE RELOAD" Style="{StaticResource SectionHeader}"/>
                        <TextBlock x:Name="LastReloadLabel" Text=""
                                   Foreground="#A6E3A1" FontFamily="Consolas" FontSize="9"
                                   TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
